import numpy as np
import matplotlib.pyplot as plt
from scipy import stats
import random

# 1. Load the file
# 'skiprows=1' removes the header text (Correlation_time_ms, G_t, Err)
file_path = 'Dat files/atto5651nM_1CP.dat'
data = np.loadtxt(file_path, skiprows=2)

# 2. Extract the columns
tau_data = data[:, 0]  # First column: Correlation_time_ms
G_data = data[:, 1]    # Second column: G_t

print(f"Imported {len(tau_data)} data points.")
print(f"First tau value: {tau_data[0]}")

y = G_data
x = tau_data

print (x)
print (y)

plt.plot (x, y, label = 'original function')
plt.legend()
plt.show()

line_model = stats.linregress(x,y)
slope = line_model[0]
intercept = line_model[1]
plt.scatter(x,y)
print (line_model)

fit_line = slope * x + intercept  # type: ignore
plt.plot (x, fit_line, label = "best fit line")
plt.legend()
plt.show()
