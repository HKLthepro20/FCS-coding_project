import numpy as np
import matplotlib.pyplot as plt
from multipletau import autocorrelate
from aicspylibczi import CziFile
import os
from tkinter import Tk, filedialog
from ptufile import PtuFile

root = Tk()
root.withdraw()
file_path = filedialog.askopenfilename(
    title="Select a file",
    filetypes=[
        ("All supported", "*.czi *.ptu *.dat"),
        ("CZI files", "*.czi"),
        ("PTU files", "*.ptu"),
        ("DAT files", "*.dat"),
        ("All files", "*.*")
    ]
)

if not file_path:
    raise FileNotFoundError("No file selected. Please select a file to continue.")
file_extension = os.path.splitext(file_path)[1].lower()
print(f"Selected file: {file_path}")

# ===== SETTINGS =====
skip_points = 2    # autocorrelation points to skip
bin_width = 1.2e-6  # seconds (adjust based on experiment)
frame_time = 1.2e-6  # seconds


if file_extension == ".czi":
    # === FUNCTIONS ===
    def get_intensity(img, point_index, detector_index):
        """Extract intensity data for a specific detector and point"""
        # Handle different dimensional structures
        if img.ndim == 6:
            return img[detector_index, :, 0, 0, :, :].reshape(-1)
        elif img.ndim == 7:
            return img[detector_index, point_index, :, 0, 0, :, :].reshape(-1)
        else:
            # Generic approach - use all available dimensions
            return img[detector_index].reshape(-1)
  
    # === LOAD CZI ===
    czi = CziFile(file_path)
    full_img, dims = czi.read_image()
    shape = full_img.shape
    print("CZI loaded, shape:", full_img.shape)
    # Identify index of the "S" dimension (spots)
    # Handle case where dims might be tuples like ('S', 5) or just strings
    dim_names = []
    for dim in dims:
        if isinstance(dim, tuple):
            dim_names.append(dim[0])
        else:
            dim_names.append(dim)

    if "S" in dim_names:
        s_index = dim_names.index("S")
        s_dim = shape[s_index]
        print(f"Found S dimension at index {s_index} with {s_dim} spots")
    else:
        s_index = None
        s_dim = 1
        print("No S dimension found, assuming 1 spot")

    print(f"Detected {s_dim} spots in file with dimensions {dims} and shape {shape}")
    print(f"S index: {s_index}, S dimension size: {s_dim}")
    print(f"Processed dim_names: {dim_names}")

    # === PROCESS EACH SPOT ===
    for s in range(s_dim):
        print(f"\n🔹 Processing Spot {s+1}")
    
        # Extract data for current spot
        # Based on your dimensions: (H=32, S=5, T=95, C=1, Z=1, Y=256, X=1024)
        # We need to be careful about the actual number of dimensions
        print(f"Full image shape: {full_img.shape}, dims: {dims}")
    
        # Find the S dimension index and extract the spot
        if s_index is not None:
            # Create indexing tuple dynamically
            indexer = [slice(None)] * full_img.ndim
            indexer[s_index] = s
            spot_img = full_img[tuple(indexer)]
        else:
            spot_img = full_img
    
        print(f"Spot {s+1} shape after extraction: {spot_img.shape}")
    
        # 32 detector channels per spot
        ffp1d = [
            get_intensity(spot_img, point_index=0, detector_index=i)
            for i in range(32)
        ]
    
        print(f"Intensity data shape for detector 0: {ffp1d[0].shape}")
        
        # Calculate autocorrelation for each detector
        gtau_p1d = [
            autocorrelate(a=ffp1d[i], deltat=frame_time, normalize=True, m=10)
            for i in range(32)
        ]
    
        # Use first 19 detectors for averaging (as in original code)
        inner_data = [gtau[skip_points:, 1] for gtau in gtau_p1d[:19]]
        tau = gtau_p1d[0][skip_points:, 0]
        mean_acf = np.mean(np.stack(inner_data), axis=0)
    
        # Plot
        plt.figure(figsize=(8, 5))
        plt.plot(tau, mean_acf, label=f"Spot {s+1}")
        plt.title(f"Autocorrelation - Spot {s+1}")
        plt.xlabel("τ (s)")
        plt.ylabel("G(τ)")
        plt.xscale("log")
        plt.ylim(0, 2)
        plt.grid(True)
        plt.legend()
        plt.tight_layout()
        plt.show()
    mean_intensity = np.mean(ffp1d, axis=0)
    time = np.arange(len(mean_intensity)) * frame_time
    plt.figure(figsize=(8, 5))
    plt.plot(time, mean_intensity)
    plt.xlabel("Time (s)")
    plt.ylabel("Intensity")
    plt.title("CZI Intensity vs Time")
    plt.grid(True)
    plt.legend()
    plt.tight_layout()
    plt.show()

elif file_extension == ".ptu":
    ptu = PtuFile(file_path)
    shape = ptu.shape
    print(f"ptu shape:{shape}")
    decoded = ptu.decode_records() # Decode photon events

    # Extract fields
    times = decoded["time"]        # macro-time
    channels = decoded["channel"]  # detector ID

    # ===== BIN INTO INTENSITY TRACE =====
    # Convert macro time to seconds
    time_resolution = ptu.global_resolution  # seconds per tick
    times_s = times * time_resolution


    t_max = times_s.max()
    bins = np.arange(0, t_max, bin_width)

    # Get number of detectors
    n_detectors = int(channels.max()) + 1

    # Build intensity traces per detector
    ffp1d = []
    for d in range(n_detectors):
        mask = channels == d
        counts, _ = np.histogram(times_s[mask], bins=bins)
        ffp1d.append(counts)
    
    mean_intensity = np.mean(ffp1d, axis=0)
    time = np.arange(len(mean_intensity)) * frame_time
    plt.figure(figsize=(8,5))
    plt.plot(time, mean_intensity)
    plt.xlabel("Time (s)")
    plt.ylabel("Intensity")
    plt.title("Intensity vs Time")
    plt.grid(True)
    plt.legend()
    plt.tight_layout()
    plt.show()




    # ===== AUTOCORRELATION =====
    frame_time = bin_width

    gtau_all = [
        autocorrelate(a=ffp1d[d].astype(np.float64),
                      deltat=frame_time,
                      normalize=True,
                      m=10)
        for d in range(n_detectors)
    ]

    # ===== AVERAGE DETECTORS =====
    inner_data = [gtau[skip_points:, 1] for gtau in gtau_all[:19]]
    tau = gtau_all[0][skip_points:, 0]
    mean_acf = np.mean(np.stack(inner_data), axis=0)

    # Plot
    plt.figure(figsize=(8, 5))
    plt.plot(tau, mean_acf, label="haha")
    plt.title(f"Autocorrelation")
    plt.xlabel("τ (s)")
    plt.ylabel("G(τ)")
    plt.xscale("log")
    plt.ylim(0, 2)
    plt.grid(True)
    plt.legend()
    plt.tight_layout()
    plt.show()
    ptu.close()


elif file_extension == ".dat":
    data = np.genfromtxt(file_path, invalid_raise=False)
    print("DAT loaded, shape:", data.shape)


else:
    print("Unsupported file type")





# ===== SAVE TO .DAT =====
base_name = os.path.splitext(os.path.basename(file_path))[0]
downloads_path = os.path.join(os.path.expanduser("~"), "Downloads")
output_file = os.path.join(downloads_path, f"{base_name}.dat")

with open(output_file, "w") as f:
    f.write(f"{base_name}\n")
    f.write("Correlation_time_s\tG_t\tErr\n")
    
    for i in range(len(tau)):
        f.write(f"{tau[i]:.12e}\t{mean_acf[i]:.12e}\t0\n")
    
    f.write("Intensity_time_s\tIntensity\tErr\n")
    for i in range(len(time)):
        f.write(f"{time[i]:.12e}\t{mean_intensity[i]:.12e}\t0\n")

print(f"Saved: {output_file}")


